/* pages/fish-post/fish-post.wxss */
page { background: linear-gradient(180deg, #F0FAF8, #E5F5F0); }

.publish-page { padding: 24rpx; min-height: 100vh; }

.text-section {
  padding: 24rpx 28rpx; margin-bottom: 20rpx;
  border-radius: var(--radius-xl);
  background: rgba(255,255,255,0.85);
}
.text-area { width: 100%; min-height: 200rpx; font-size: 30rpx; color: #3A5A50; line-height: 1.7; }
.text-count { text-align: right; margin-top: 12rpx; }

.image-section {
  padding: 24rpx; margin-bottom: 20rpx;
  border-radius: var(--radius-xl);
  background: rgba(255,255,255,0.85);
}
.image-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.img-item {
  width: 208rpx; height: 208rpx; border-radius: var(--radius-md);
  position: relative; overflow: hidden; background: #E8F5F2;
}
.img-thumb { width: 100%; height: 100%; object-fit: cover; }
.img-delete {
  position: absolute; top: 4rpx; right: 4rpx;
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: rgba(0,0,0,0.5); color: #FFF;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx;
}
.img-add {
  display: flex; align-items: center; justify-content: center;
  border: 3rpx dashed rgba(126,200,200,0.5);
}
.add-icon { font-size: 60rpx; color: #A8DDD8; font-weight: 300; }
.image-hint { text-align: center; padding: 20rpx 0; }

.submit-section { margin-top: 40rpx; padding: 0 20rpx; }
.publish-btn {
  height: 100rpx; border-radius: 60rpx; font-size: 34rpx; font-weight: 800;
  letter-spacing: 6rpx;
  background: linear-gradient(135deg, #7EC8C8, #A8DDD8);
  box-shadow: 0 12rpx 36rpx rgba(126,200,200,0.4);
  color: #FFF;
}
