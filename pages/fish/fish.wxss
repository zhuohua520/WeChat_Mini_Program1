/* pages/fish/fish.wxss — 浅青碧波摸鱼页 */
page { background: linear-gradient(180deg, #F0FAF8 0%, #E5F5F0 100%); }

.fish-page {
  padding: 24rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
}

/* ===== 动态卡片 ===== */
.post-list { display: flex; flex-direction: column; gap: 20rpx; }
.post-card {
  padding: 28rpx;
  border-radius: var(--radius-xl);
  background: rgba(255,255,255,0.82);
  box-shadow: 0 8rpx 32rpx rgba(126,200,200,0.1);
}

.post-header { margin-bottom: 16rpx; }
.post-user { gap: 14rpx; }
.post-avatar, .post-avatar-placeholder {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
}
.post-avatar-placeholder {
  background: linear-gradient(135deg, #7EC8C8, #A8DDD8);
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #FFF; font-weight: 700;
}
.post-avatar { object-fit: cover; }
.post-name { font-size: 28rpx; font-weight: 700; color: #3A5A50; }
.post-time { font-size: 22rpx; margin-top: 2rpx; }
.post-delete-hint { font-size: 20rpx; opacity: 0.5; }
.post-text {
  font-size: 28rpx; color: #4A5A55; line-height: 1.7;
  margin-bottom: 16rpx; word-break: break-all;
}

/* 图片 */
.post-images { margin-bottom: 16rpx; }
.post-image-grid { display: flex; gap: 8rpx; flex-wrap: wrap; }
.post-img {
  border-radius: var(--radius-md);
  background: #E8F5F2;
}
.img-1 .post-img { width: 100%; height: 360rpx; }
.img-2 .post-img { width: calc(50% - 4rpx); height: 260rpx; }
.img-multi .post-img { width: calc(33.33% - 6rpx); height: 220rpx; }

/* 互动栏 */
.post-actions {
  padding-top: 16rpx; border-top: 1rpx solid rgba(126,200,200,0.2);
}
.action-item {
  display: flex; align-items: center; gap: 6rpx;
  padding: 10rpx 20rpx; border-radius: 40rpx;
  font-size: 30rpx; transition: all 0.2s;
}
.action-item:active { background: rgba(126,200,200,0.1); }
.action-count { font-size: 24rpx; color: var(--text-secondary); }
.liked { background: rgba(255,182,193,0.2); }

/* 评论 */
.post-comments {
  margin-top: 16rpx; padding: 16rpx;
  background: rgba(126,200,200,0.06); border-radius: var(--radius-md);
}
.comment-item {
  padding: 8rpx 0; font-size: 26rpx; line-height: 1.6;
  border-bottom: 1rpx solid rgba(126,200,200,0.1);
}
.comment-name { color: #3A8A80; font-weight: 600; }
.comment-text { color: #5A6A65; }

.comment-input-row {
  display: flex; align-items: center; gap: 12rpx;
  margin-top: 16rpx; padding-top: 12rpx;
  border-top: 1rpx solid rgba(126,200,200,0.2);
}
.comment-input {
  flex: 1; height: 64rpx;
  background: rgba(255,255,255,0.8);
  border-radius: 32rpx; padding: 0 24rpx;
  font-size: 26rpx;
}
.comment-send {
  font-size: 26rpx; color: #3A8A80; font-weight: 600;
  padding: 10rpx 20rpx;
}
.comment-send:active { opacity: 0.6; }

/* FAB 按钮 */
.fab-btn {
  position: fixed; bottom: 160rpx; right: 40rpx;
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: linear-gradient(135deg, #7EC8C8, #A8DDD8);
  box-shadow: 0 12rpx 36rpx rgba(126,200,200,0.4);
  display: flex; align-items: center; justify-content: center;
  z-index: 10; transition: transform 0.2s;
}
.fab-btn:active { transform: scale(0.9); }
.fab-icon { font-size: 44rpx; }

.load-more { text-align: center; padding: 32rpx 0; }
